# Copy to .env in this folder (NEVER commit .env)

DB_URL=jdbc:postgresql://localhost:5432/alp_ai
DB_USERNAME=postgres
DB_PASSWORD=your_database_password

JWT_SECRET=alp-dev-secret-key-minimum-256-bits-long-for-hs256-algorithm-ok

# ── OpenAI (required for AI features) ───────────────────────────────────────
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Cheap model for testing (~$0.15/1M input tokens)
# TODO: Change to gpt-4o or tier-based routing before production / premium launch
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.7

# Path to /prompts folder (relative to services/ai-service when running locally)
PROMPTS_DIR=../../prompts
